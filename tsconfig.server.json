{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "plugins": [{ "transform": "typia/lib/transform" }]
  },
  "include": ["server.ts", "validators/**/*"]
}
