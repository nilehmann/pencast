{
  "name": "pencast",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run server:dev\"",
    "dev:client": "vite --config client/vite.config.ts --host",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "server": "node dist/server.js",
    "server:dev": "tsx watch server.ts /home/nlehmann/teaching/cc3301/2026-01 --crop-top 32",
    "typecheck": "svelte-check --tsconfig client/tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build:embed": "bun run scripts/embed-client.ts",
    "build:bundle": "bun build --compile --target=bun server.ts --outfile pencast",
    "bundle": "npm run build:client && npm run build:embed && npm run build:bundle",
    "generate:validators": "typia generate --input validators --output generated --project tsconfig.server.json",
    "lint": "eslint server.ts shared client/src",
    "install": "npm run bundle && mv pencast ~/.local/bin"
  },
  "dependencies": {
    "@flatten-js/core": "^1.6.10",
    "interactive-shape-recognition": "^1.0.1",
    "lucide-svelte": "^0.577.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.9.155",
    "perfect-freehand": "^1.2.2",
    "typia": "^12.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.7"
  }
}
